---
import { getAllTags, getPostsByTag, slugify } from '../../utils/posts';
import BaseLayout from '../../layouts/BaseLayout.astro';

const tags = await getAllTags();

// Build count map
const tagCounts: Record<string, number> = {};
for (const tag of tags) {
  const posts = await getPostsByTag(tag);
  tagCounts[tag] = posts.length;
}
---

<BaseLayout title="Tags — Hayub Idowu" description="Browse posts by tag.">
  <header class="mb-8">
    <h1 class="font-display text-3xl font-bold text-text">Tags</h1>
    <p class="mt-1 text-sm text-muted">{tags.length} tag{tags.length !== 1 ? 's' : ''}</p>
  </header>

  <div class="flex flex-wrap gap-3">
    {tags.map(tag => (
      <a
        href={`/tags/${slugify(tag)}`}
        class="flex items-center gap-2 rounded-[--radius-card-val] border border-border-color bg-surface px-3 py-2 text-sm text-text hover:border-accent hover:text-accent transition-colors"
      >
        <span class="text-accent">#</span>{tag}
        <span class="ml-1 rounded-full bg-tag-bg px-1.5 py-0.5 text-xs text-muted">
          {tagCounts[tag]}
        </span>
      </a>
    ))}
  </div>
</BaseLayout>
